# ===============================
# Database Configuration
# ===============================

PGUSER=your_db_user
PGPASSWORD=your_db_password

DATABASE_URL=postgresql://your_db_user:your_db_password@your-host.neon.tech/your_database?sslmode=require

# ===============================
# JWT Configuration
# ===============================

JWT_SECRET=your_super_secret_jwt_key

# ===============================
# App Configuration (Optional)
# ===============================

APP_ENV=development
APP_PORT=8080
